// Copy this file to `secrets.h` in the same folder and fill in real
// values. `secrets.h` is git-ignored so credentials never get pushed.
//
// Where to find each value:
//   SUPABASE_URL / SUPABASE_ANON_KEY
//     Supabase Dashboard -> Project Settings -> API.
//     These match what the mobile app already uses (.env in the repo
//     root, EXPO_PUBLIC_SUPABASE_URL / EXPO_PUBLIC_SUPABASE_ANON_KEY).
//
//   ZONE_ID
//     Supabase Studio -> Table Editor -> public.zones -> the row you
//     want this circuit to act on -> copy `id` (uuid).
//
//   DEVICE_SECRET
//     Supabase Studio -> Table Editor -> public.devices ->
//     find the device row that owns the zone above -> copy
//     `device_secret` (uuid). Anyone with this can post readings to
//     that one zone, so keep `secrets.h` out of git.
//
//   WIFI_SSID / WIFI_PASSWORD
//     For Wokwi's free in-browser WiFi: SSID = "Wokwi-GUEST",
//     password = "" (empty string). For real boards, your AP.

#pragma once

#define WIFI_SSID         "Wokwi-GUEST"
#define WIFI_PASSWORD     ""

#define SUPABASE_URL      "https://YOUR-PROJECT.supabase.co"
#define SUPABASE_ANON_KEY "YOUR_SUPABASE_ANON_KEY"

#define ZONE_ID           "00000000-0000-0000-0000-000000000000"
#define DEVICE_SECRET     "00000000-0000-0000-0000-000000000000"
